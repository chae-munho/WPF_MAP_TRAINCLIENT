<Window x:Class="TrainClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrainClient"
        Height="760"
        Width="1280"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="관제 WS 주소:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtServerUrl"
                         Width="340"
                         Text="ws://192.168.0.173:5090/ws/train"
                         Margin="0,0,10,0"/>

                <TextBlock Text="GPS COM:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtGpsPort" Width="100" Text="COM6" Margin="0,0,10,0"/>

                <TextBlock Text="Baud:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtBaudRate" Width="100" Text="9600" Margin="0,0,10,0"/>

                <Button x:Name="btnConnect"
                        Content="처음부터 접속"
                        Width="120"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="btnConnect_Click"/>

                <Button x:Name="btnResumeConnect"
                        Content="이어서 접속"
                        Width="120"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="btnResumeConnect_Click"/>

                <Button x:Name="btnDisconnect"
                        Content="연결 종료"
                        Width="120"
                        Height="32"
                        Click="btnDisconnect_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,10" Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="WebSocket 상태: " FontWeight="Bold"/>
                <TextBlock x:Name="txtWsStatus" Text="미연결" Margin="0,0,20,0"/>

                <TextBlock Text="GPS 연결 상태: " FontWeight="Bold"/>
                <TextBlock x:Name="txtGpsStatus" Text="미연결" Margin="0,0,20,0"/>

                <TextBlock Text="현재 위도: " FontWeight="Bold"/>
                <TextBlock x:Name="txtLat" Text="-" Margin="0,0,20,0"/>

                <TextBlock Text="현재 경도: " FontWeight="Bold"/>
                <TextBlock x:Name="txtLng" Text="-"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="0,0,0,10" Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="마지막 제어명령: " FontWeight="Bold"/>
                <TextBlock x:Name="txtLastCommand" Text="-" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="로그" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left"/>
                    <Button Content="로그 지우기" Width="100" Height="28" DockPanel.Dock="Right" Click="ClearLog_Click"/>
                </DockPanel>

                <TextBox x:Name="txtLog"
                         Grid.Row="1"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>