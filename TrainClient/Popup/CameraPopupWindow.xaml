<Window x:Class="TrainClient.Popups.CameraPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="인터컴 카메라 팝업"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="1.4*"/>
        </Grid.ColumnDefinitions>

        <!-- 좌측 카메라 영역 -->
        <Border Grid.Column="0"
                CornerRadius="10"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Background="Black"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
                    <TextBlock x:Name="txtSelectedTitle"
                               Text="선택된 호출 없음"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="txtSelectedUrl"
                               Text="-"
                               Foreground="#BFBFBF"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Row="1"
                        CornerRadius="8"
                        Background="Black"
                        BorderBrush="#444444"
                        BorderThickness="1">
                    <Grid>
                        <ContentControl x:Name="VideoHost"/>
                        <TextBlock x:Name="txtVideoPlaceholder"
                                   Text="영상 없음"
                                   Foreground="#9A9A9A"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Margin="0,8,0,0"
                           Foreground="#CFCFCF"
                           FontSize="12"
                           Text="현재는 1~12번 객차 URL이 모두 동일하게 설정되어 있음"/>
            </Grid>
        </Border>

        <!-- 우측 알람 리스트 -->
        <Border Grid.Column="2"
                CornerRadius="10"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Background="#252525"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="호출 알람 리스트"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="lstAlarms"
                         Grid.Row="1"
                         Background="#1F1F1F"
                         Foreground="White"
                         BorderThickness="0"
                         SelectionChanged="lstAlarms_SelectionChanged"
                         DisplayMemberPath="DisplayText"/>
            </Grid>
        </Border>
    </Grid>
</Window>